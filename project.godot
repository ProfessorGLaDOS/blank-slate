; Engine configuration file.
; It's best edited using the editor UI and not directly,
; but it can also be edited via text if you know what you're doing.

config_version=5

[application]

config/name="Blank Slate"
run/main_scene=""
config/features=PackedStringArray("4.3", "GL Compatibility")

[autoload]

GameManager="*res://autoloads/game_manager.gd"
SaveManager="*res://autoloads/save_manager.gd"
AudioManager="*res://autoloads/audio_manager.gd"
InputManager="*res://autoloads/input_manager.gd"
ElementDB="*res://autoloads/element_database.gd"
HitStop="*res://autoloads/hit_stop.gd"
InputBuffer="*res://autoloads/input_buffer.gd"

[display]

window/size/viewport_width=960
window/size/viewport_height=540
window/size/window_width_override=1920
window/size/window_height_override=1080
window/stretch/mode="canvas_items"
window/stretch/aspect="keep"

